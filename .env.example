# ================================================================
# VARIÁVEIS DE AMBIENTE — App Finanças Pessoais
# ================================================================
# Copie este arquivo para .env.local e preencha com seus valores.
# Nunca commite o .env.local — ele já está no .gitignore.
#
# Como obter os valores:
#   1. Acesse https://supabase.com e abra seu projeto
#   2. Vá em Project Settings → API
#   3. Copie a "Project URL" e a "Publishable (anon) key"
# ================================================================

# --- Expostas ao browser (prefixo NEXT_PUBLIC_ obrigatório) ---
# Seguras de expor: protegidas pelas políticas de RLS do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_SUA_CHAVE_AQUI

# --- Server-only (sem prefixo NEXT_PUBLIC_, nunca chegam ao browser) ---
# Usadas exclusivamente em Server Components, Server Actions e Proxy
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_SUA_CHAVE_AQUI
